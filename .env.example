# Job Scout — API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# .env is NOT committed to git (see .gitignore)

# Required: OpenAI — used for job scoring (gpt-4o-mini)
OPENAI_API_KEY=sk-proj-...

# Optional: Anthropic — used for cover letter generation (claude-3-5-sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Serper — used for company discovery via Google Dorks
SERPER_API_KEY=...
